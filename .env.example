# Database Configuration
MONGO_URI=mongodb+srv://username:password@cluster.mongodb.net/db_name

# JWT Configuration
JWT_SECRET=your_jwt_secret_key_at_least_32_characters_long
REFRESH_SECRET=your_refresh_secret_key_at_least_32_characters_long

# OAuth Configuration
# Get these from your OAuth provider applications
GITHUB_CLIENT_ID=your_github_client_id
GITHUB_CLIENT_SECRET=your_github_client_secret
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
LINKEDIN_CLIENT_ID=your_linkedin_client_id
LINKEDIN_CLIENT_SECRET=your_linkedin_client_secret

# Portfolio Owner OAuth ID (for admin access)
# This should be the oauthId of your portfolio owner account
PORTFOLIO_OWNER_OAUTH_ID=your_portfolio_owner_oauth_id

# Server Configuration
PORT=5000
NODE_ENV=development

# CORS Configuration
# Add your frontend URL here
FRONTEND_URL=http://localhost:3000

# Rate Limiting Configuration
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100
